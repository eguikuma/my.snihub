{
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 80,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "^(react|next)(/?.*|$)",
    "<THIRD_PARTY_MODULES>",
    "^@/foundations/(.*)$",
    "^@/features/(.*)$",
    "^@/(.*)$",
    "^[.]"
  ],
  "importOrderTypeScriptVersion": "5.0.0"
}
